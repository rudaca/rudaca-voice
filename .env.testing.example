# Rudaca Voice — testing environment template
#
# Copy to `.env.testing` for local runs, or export these as env vars in CI.
# NOTE: phpunit.xml already provides SQLite (:memory:) defaults for quick local
# runs. Values set in the real environment (e.g. CI) take precedence over
# phpunit.xml's <env> entries, which is how we run the suite against MySQL in CI.

APP_NAME="Rudaca Voice"
APP_ENV=testing
# Generate once with: php artisan key:generate --env=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# --- Database (CI: MySQL/MariaDB, matching production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rudaca_voice_testing
DB_USERNAME=root
DB_PASSWORD=password

# --- Local quick-run alternative (uncomment to use SQLite instead) ---
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

# --- Fast, side-effect-free drivers for tests ---
BCRYPT_ROUNDS=4
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
FILESYSTEM_DISK=local

# --- Disable dev/observability integrations during tests ---
TELESCOPE_ENABLED=false
PULSE_ENABLED=false
NIGHTWATCH_ENABLED=false
